{
  "name": "riptide",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "wgsl-check": "node scripts/wgsl-check.mjs",
    "build:native": "cd native && zig build -Doptimize=ReleaseSafe && mkdir -p ../dist/native && cp zig-out/lib/libriptide.so ../dist/native/riptide.node && cp zig-out/bin/query-fixture ../dist/native/query-fixture && cp src/mock.vcd src/mock.vcd.sidecar.json ../dist/native/",
    "test": "tests/run.sh",
    "test:differential": "node --test tests/differential.test.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build": "pnpm wgsl-check && pnpm build:native && tsc -p tsconfig.json && node scripts/build-ui.mjs",
    "build:prod": "NODE_ENV=production pnpm build",
    "dist": "pnpm build:prod && electron-builder",
    "dist:dir": "pnpm build:prod && electron-builder --dir",
    "dev": "pnpm build && electron .",
    "dev:ui": "pnpm wgsl-check && pnpm build:native && node scripts/dev-ui.mjs",
    "canvas-test": "node scripts/canvas-test/build.mjs && deno run --allow-all scripts/canvas-test/harness.bundle.mjs",
    "canvas-test:update": "node scripts/canvas-test/build.mjs && deno run --allow-all scripts/canvas-test/harness.bundle.mjs --update",
    "canvas-test:equiv": "node scripts/canvas-test/build.mjs && deno run --allow-all scripts/canvas-test/harness.bundle.mjs --equiv"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.50",
    "babel-preset-solid": "^1.9.12",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.riptide.app",
    "productName": "Riptide",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/native/**"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@melloware/coloris": "^0.25.0",
    "@solid-primitives/keyed": "^1.5.3",
    "@tanstack/solid-virtual": "^3.13.28",
    "lucide-solid": "^1.17.0",
    "solid-js": "^1.9.13",
    "solid-zustand": "^2.0.0",
    "zustand": "^5.0.14"
  }
}
