{
  "name": "riptide",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "wgsl-check": "node scripts/wgsl-check.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build": "pnpm wgsl-check && tsc -p tsconfig.json && mkdir -p dist/renderer && esbuild src/renderer/index.tsx --bundle --outfile=dist/renderer/index.js --format=iife --target=es2022 --loader:.tsx=tsx --loader:.wgsl=text --jsx=automatic && cp src/renderer/index.html dist/renderer/index.html",
    "dev": "pnpm build && electron .",
    "dev:ui": "pnpm wgsl-check && node scripts/dev-ui.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@webgpu/types": "^0.1.50",
    "electron": "^41.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "lucide-react": "1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
